# 服务配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=health_management
DB_USER=root
DB_PASSWORD=123456

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=health-management-secret-key-2024
JWT_EXPIRES_IN=24h

# 医院接口配置
HOSPITAL_API_BASE=https://api.hospital.com/v1
HOSPITAL_API_KEY=hospital-api-key-example

# 企业微信/钉钉推送配置
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 文件存储路径
UPLOAD_PATH=./uploads
REPORT_PATH=./reports

# 日志配置
LOG_LEVEL=info
LOG_PATH=./logs
